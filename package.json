{
  "name": "claude-usage",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:mac": "env-cmd tauri build --target aarch64-apple-darwin",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "bump": "npm version --no-git-tag-version",
    "version": "node -e \"const f='src-tauri/tauri.conf.json';const c=JSON.parse(require('fs').readFileSync(f));c.version=require('./package.json').version;require('fs').writeFileSync(f,JSON.stringify(c,null,2)+'\\n')\"",
    "update-server": "cargo run --release --manifest-path tools/update-server/Cargo.toml",
    "update-server:prepare": "bash tools/update-server/prepare.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-positioner": "~2.3.1",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "env-cmd": "^11.0.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}