{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Token Juice",
  "version": "0.1.0",
  "identifier": "com.tokenjuice.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3008",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Token Juice",
        "width": 70,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxNTQ0REE3MkEzRDE3NDAKUldSQUZ6MHFwMDFVY1hlMU5ucDRmMDRucUNmSkc5eWFxTmxmSlRFOXdZdEgxdmRtOEkwVDhWK2UK",
      "endpoints": [
        "https://localhost:8443/latest.json"
      ]
    }
  }
}